# Cloudflare Pages: per-file response headers.

# Long cache for static assets — they're tiny and only change when you redeploy.
/styles.css
  Cache-Control: public, max-age=3600
/game.js
  Cache-Control: public, max-age=3600

# Never cache the API or the HTML shell.
/index.html
  Cache-Control: no-cache
/api/*
  Cache-Control: no-store
